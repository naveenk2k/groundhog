{
  "manifest_version": 3,
  "name": "Groundhog",
  "version": "0.1.0",
  "description": "Checks a YouTube video against your watch history before you sink time into it.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Ctrl+G",
        "mac": "Command+G"
      },
      "description": "Show or hide the Groundhog overlay on the current video"
    },
    "toggle-options": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Open or close the Groundhog options page"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["debug-log.js", "video-id.js", "watch-tracker.js", "overlay-state.js", "overlay.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "512": "icons/groundhog.png"
  }
}
